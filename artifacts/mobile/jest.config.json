{
  "preset": "jest-expo",
  "testEnvironment": "node",
  "setupFilesAfterFramework": ["@testing-library/react-native/extend-expect"],
  "transformIgnorePatterns": [
    "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|expo-speech|expo-file-system|expo-secure-store|expo-device|expo-constants)"
  ],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/$1"
  },
  "testMatch": [
    "**/__tests__/**/*.test.ts",
    "**/__tests__/**/*.test.tsx"
  ],
  "collectCoverageFrom": [
    "utils/tts.ts",
    "utils/storage.ts",
    "utils/security/app-license.ts",
    "contexts/ThemeContext.tsx",
    "contexts/OverlayContext.tsx"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 70,
      "functions": 80,
      "lines": 80,
      "statements": 80
    }
  }
}
